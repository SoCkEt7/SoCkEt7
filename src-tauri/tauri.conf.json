{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "hydra-nexus",
  "version": "0.1.0",
  "identifier": "com.hydra.nexus",
  "build": {
    "frontendDist": "../../hydra/frontend/dist",
    "devUrl": "http://localhost:31173",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "HYDRA // NEXUS",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
